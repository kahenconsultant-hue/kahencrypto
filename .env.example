# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
INGESTION_CRON_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret
CMIP_ALLOW_DEV_FALLBACK=false
CMIP_SIGNAL_CACHE_PATH=.cache/cmip/latest-signals.json
CMIP_INGESTION_STORE_PATH=.cache/cmip/ingestion

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis / Queue
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
AI_MODEL=gpt-4.1
AI_PROMPT_VERSION=crypto-macro-v1

# Data providers
COINGECKO_API_KEY=
FRED_API_KEY=
TRADING_ECONOMICS_KEY=
TRADINGECONOMICS_API_KEY=
GLASSNODE_API_KEY=
NANSEN_API_KEY=
CRYPTOQUANT_API_KEY=
COINMETRICS_API_KEY=
SANTIMENT_API_KEY=
COINGLASS_API_KEY=
WHALE_ALERT_API_KEY=
X_BEARER_TOKEN=
YOUTUBE_API_KEY=

# Optional configured feeds when no public endpoint exists
CMIP_BTC_ETF_FLOW_24H=
CMIP_BTC_ETF_FLOW_7D=
CMIP_BTC_ETF_FLOW_24H_TIMESTAMP=
CMIP_ETH_ETF_FLOW_24H=
CMIP_ETH_ETF_FLOW_7D=
CMIP_ETH_ETF_FLOW_24H_TIMESTAMP=
CMIP_BTC_EXCHANGE_RESERVES_7D=
CMIP_BTC_EXCHANGE_RESERVES_7D_TIMESTAMP=

# WordPress / widgets
WORDPRESS_SHARED_SECRET=
EMBED_ALLOWED_ORIGINS=*
