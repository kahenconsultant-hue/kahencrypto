# C.M.I.P local production-like environment

# App
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3004
INGESTION_CRON_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret
CMIP_ALLOW_DEV_FALLBACK=false
CMIP_SIGNAL_CACHE_PATH=.cache/cmip/latest-signals.json
CMIP_INGESTION_STORE_PATH=.cache/cmip/ingestion

# Supabase, required for production persistence
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional AI, not used in Phase 4 ingestion persistence
OPENAI_API_KEY=

# Optional data providers
COINGECKO_API_KEY=
TRADINGECONOMICS_API_KEY=
COINGLASS_API_KEY=
FRED_API_KEY=
WHALE_ALERT_API_KEY=
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=

# Optional manually configured feeds when no reliable free endpoint is enabled.
# Leave empty unless values come from a real maintained source. Empty values stay Missing.
CMIP_BTC_ETF_FLOW_24H=
CMIP_BTC_ETF_FLOW_7D=
CMIP_BTC_ETF_FLOW_24H_TIMESTAMP=
CMIP_ETH_ETF_FLOW_24H=
CMIP_ETH_ETF_FLOW_7D=
CMIP_ETH_ETF_FLOW_24H_TIMESTAMP=
CMIP_BTC_EXCHANGE_RESERVES_7D=
