{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["confidence", "decision_memory"],
  "properties": {
    "confidence": {
      "type": "object",
      "required": ["raw", "final", "cap", "components"],
      "properties": {
        "raw": { "type": "number", "minimum": 0, "maximum": 100 },
        "final": { "type": "number", "minimum": 0, "maximum": 100 },
        "cap": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "components": { "type": "array" }
      },
      "additionalProperties": true
    },
    "decision_memory": { "type": "object" }
  }
}
