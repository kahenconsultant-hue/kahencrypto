{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmip.local/gemini/execution-result-schema.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "executionVersion",
    "executionId",
    "packageId",
    "semanticPackageHash",
    "providerId",
    "providerExecutionVersion",
    "status",
    "report",
    "provider",
    "usage",
    "timing",
    "validation",
    "attempts",
    "warnings",
    "errors",
    "trace"
  ],
  "properties": {
    "executionVersion": { "const": "CMIP-PROVIDER-EXECUTION-1.0" },
    "executionId": { "type": "string", "minLength": 1 },
    "packageId": { "type": "string", "minLength": 1 },
    "semanticPackageHash": { "$ref": "#/$defs/hash" },
    "providerId": { "const": "gemini" },
    "providerExecutionVersion": { "type": "string", "minLength": 1 },
    "status": { "enum": ["success", "failed", "refused", "incomplete"] },
    "report": { "type": ["object", "null"] },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "responseId", "model", "rawStatus", "serviceTier"],
      "properties": {
        "name": { "const": "gemini" },
        "responseId": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "rawStatus": { "type": ["string", "null"] },
        "serviceTier": { "type": ["string", "null"] }
      }
    },
    "usage": { "$ref": "#/$defs/usage" },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "completedAt", "durationMs"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerSchemaCompatible", "jsonParsed", "canonicalValid", "repairAttempted", "repairSucceeded"],
      "properties": {
        "providerSchemaCompatible": { "type": "boolean" },
        "jsonParsed": { "type": "boolean" },
        "canonicalValid": { "type": "boolean" },
        "repairAttempted": { "type": "boolean" },
        "repairSucceeded": { "type": "boolean" }
      }
    },
    "attempts": { "type": "array", "items": { "$ref": "#/$defs/attempt" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "trace": { "type": "object" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableInteger": { "type": ["integer", "null"], "minimum": 0 },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputTokens", "cachedInputTokens", "outputTokens", "reasoningTokens", "totalTokens"],
      "properties": {
        "inputTokens": { "$ref": "#/$defs/nullableInteger" },
        "cachedInputTokens": { "$ref": "#/$defs/nullableInteger" },
        "outputTokens": { "$ref": "#/$defs/nullableInteger" },
        "reasoningTokens": { "$ref": "#/$defs/nullableInteger" },
        "totalTokens": { "$ref": "#/$defs/nullableInteger" }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "attemptIndex", "startedAt", "completedAt", "status", "providerRawStatus", "errorCode", "retryDelayMs"],
      "properties": {
        "providerId": { "const": "gemini" },
        "attemptIndex": { "type": "integer", "minimum": 0 },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "status": { "enum": ["success", "failed", "refused", "incomplete"] },
        "providerRawStatus": { "type": ["string", "null"] },
        "errorCode": { "type": ["string", "null"] },
        "retryDelayMs": { "type": "integer", "minimum": 0 }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message", "domain", "severity", "retryable", "sourceRefs"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "domain": { "enum": ["gemini", "provider_router", "openai"] },
        "severity": { "enum": ["info", "warning", "error", "critical"] },
        "retryable": { "type": "boolean" },
        "sourceRefs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
